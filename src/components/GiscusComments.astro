---
// Giscus 评论组件
const containerId = "giscus-container";
---

<div id={containerId}></div>

<script is:inline>
  (() => {
    const containerId = "giscus-container";
    const stateKey = "__fuwariGiscusState";
    const state = (window[stateKey] ||= {
      themeObserver: null,
      initHandler: null,
      cleanupHandler: null,
    });

    // 获取当前主题
    function getCurrentTheme() {
      const isDark = document.documentElement.classList.contains("dark");
      return isDark ? "dark" : "light";
    }

    // 加载 Giscus
    function loadGiscus() {
      const container = document.getElementById(containerId);
      if (!container) return;

      container.innerHTML = "";

      const script = document.createElement("script");
      script.src = "https://giscus.app/client.js";
      script.setAttribute("data-repo", "suichyan/fuwari");
      script.setAttribute("data-repo-id", "R_kgDORKQy1A");
      script.setAttribute("data-category", "Announcements");
      script.setAttribute("data-category-id", "DIC_kwDOPbFVy84Ct-aR");
      script.setAttribute("data-mapping", "pathname");
      script.setAttribute("data-strict", "0");
      script.setAttribute("data-reactions-enabled", "1");
      script.setAttribute("data-emit-metadata", "0");
      script.setAttribute("data-input-position", "top");
      script.setAttribute("data-theme", getCurrentTheme());
      script.setAttribute("data-lang", "zh-CN");
      script.setAttribute("data-loading", "lazy");
      script.setAttribute("crossorigin", "anonymous");
      script.async = true;

      container.appendChild(script);
    }

    // 监听主题变化
    function observeThemeChange() {
      if (state.themeObserver) {
        state.themeObserver.disconnect();
      }

      state.themeObserver = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (
            mutation.type === "attributes" &&
            mutation.attributeName === "class"
          ) {
            const giscusFrame = document.querySelector("iframe.giscus-frame");
            if (giscusFrame && giscusFrame.contentWindow) {
              const theme = getCurrentTheme();
              try {
                giscusFrame.contentWindow.postMessage(
                  {
                    giscus: {
                      setConfig: {
                        theme: theme,
                      },
                    },
                  },
                  "*",
                );
              } catch (error) {
                console.debug("Giscus theme update failed:", error);
              }
            }
          }
        });
      });

      state.themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });
    }

    // 初始化函数
    function initGiscus() {
      loadGiscus();
      observeThemeChange();
    }

    // 清理函数
    function cleanupGiscus() {
      if (state.themeObserver) {
        state.themeObserver.disconnect();
        state.themeObserver = null;
      }
      const container = document.getElementById(containerId);
      if (container) {
        container.innerHTML = "";
      }
    }

    // 重复注入脚本时，先解除旧监听，避免重复注册
    if (state.initHandler) {
      document.removeEventListener("swup:contentReplaced", state.initHandler);
      document.removeEventListener("DOMContentLoaded", state.initHandler);
      document.removeEventListener("astro:page-load", state.initHandler);
    }
    if (state.cleanupHandler) {
      document.removeEventListener(
        "swup:willReplaceContent",
        state.cleanupHandler,
      );
    }

    state.initHandler = initGiscus;
    state.cleanupHandler = cleanupGiscus;

    document.addEventListener("swup:contentReplaced", state.initHandler);
    document.addEventListener("swup:willReplaceContent", state.cleanupHandler);
    document.addEventListener("DOMContentLoaded", state.initHandler);
    document.addEventListener("astro:page-load", state.initHandler);

    if (document.readyState !== "loading") {
      initGiscus();
    }
  })();
</script>
